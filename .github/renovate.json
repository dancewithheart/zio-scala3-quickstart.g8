{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests"
  ],
  "dependencyDashboard": true,
  "labels": ["dependencies", "security"],
  "assignees": ["dancewithheart"],
  "timezone": "Europe/Warsaw",
  "schedule": ["before 9am on monday"],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "minimumReleaseAge": "7 days",
  "internalChecksFilter": "strict",
  "prCreation": "not-pending",
  "separateMajorMinor": true,
  "separateMinorPatch": false,
  "packageRules": [
    {
      "description": "Group non-major sbt dependency updates",
      "matchManagers": ["sbt"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "sbt dependencies",
      "minimumReleaseAge": "7 days"
    },
    {
      "description": "Keep major sbt updates separate for review",
      "matchManagers": ["sbt"],
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true,
      "labels": ["dependencies", "security", "major-update"]
    },
    {
      "description": "Group GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "groupName": "github-actions",
      "minimumReleaseAge": "7 days"
    },
    {
      "description": "Require manual approval for major GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true,
      "labels": ["dependencies", "security", "github-actions", "major-update"]
    },
    {
      "description": "Do not automerge by default in this security template",
      "matchUpdateTypes": ["major", "minor", "patch", "digest"],
      "automerge": false
    }
  ],
  "customManagers": [
    {
      "description": "Update scala3_version in Giter8 default.properties",
      "customType": "regex",
      "managerFilePatterns": ["/^src/main/g8/default\\.properties$/"],
      "matchStrings": [
        "scala3_version=(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "org.scala-lang:scala3-library_3",
      "datasourceTemplate": "maven",
      "versioningTemplate": "semver"
    }
  ]
}
